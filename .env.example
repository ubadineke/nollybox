# Nollybox runs fully on the mock store by default — no env needed.
# To connect it to a real Plinth tenant, set PLINTH_MODE=live and fill the rest.

# mock | live  (server-side switch for the API routes)
PLINTH_MODE=mock

# Client-readable mirror of the mode (so the UI knows whether to call the server routes
# or use the local mock store). Keep it in sync with PLINTH_MODE.
NEXT_PUBLIC_PLINTH_MODE=mock

# Plinth engine + Nollybox's tenant API key (server-only — never NEXT_PUBLIC_)
PLINTH_API_URL=http://localhost:7331
PLINTH_API_KEY=

# No plan ids here. Plans are resolved dynamically by lookup_key:
#   standard_monthly · standard_annual · premium_monthly
# Set those as each plan's "Lookup key" on the Plinth dashboard (Catalog → Add Plan).
